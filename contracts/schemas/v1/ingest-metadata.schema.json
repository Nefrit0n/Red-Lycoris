{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://red-lycoris.dev/contracts/schemas/v1/ingest-metadata.schema.json",
  "title": "IngestMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "producer", "tenant", "gitlab_context", "git", "run"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "build"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "build": { "type": "string", "minLength": 1 }
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["org_id"],
      "properties": {
        "org_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 }
      }
    },
    "gitlab_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ci_pipeline_id": { "type": "string" },
        "ci_pipeline_iid": { "type": "string" },
        "ci_pipeline_url": { "type": "string", "format": "uri" },
        "ci_job_id": { "type": "string" },
        "ci_job_url": { "type": "string", "format": "uri" },
        "ci_job_name": { "type": "string" },
        "ci_job_stage": { "type": "string" },
        "ci_project_id": { "type": "string" },
        "ci_project_path": { "type": "string" },
        "ci_project_url": { "type": "string", "format": "uri" },
        "ci_commit_sha": { "type": "string" },
        "ci_commit_ref_name": { "type": "string" },
        "ci_commit_tag": { "type": "string" },
        "ci_commit_branch": { "type": "string" }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_url", "ref", "sha"],
      "properties": {
        "repo_url": { "type": "string", "format": "uri" },
        "ref": { "type": "string" },
        "sha": { "type": "string", "pattern": "^[a-fA-F0-9]{40}$" },
        "message": { "type": "string" },
        "authored_at": { "type": "string", "format": "date-time" },
        "committed_at": { "type": "string", "format": "date-time" }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline_id", "job_id", "started_at"],
      "properties": {
        "pipeline_id": { "type": "string" },
        "pipeline_url": { "type": "string", "format": "uri" },
        "job_id": { "type": "string" },
        "job_url": { "type": "string", "format": "uri" },
        "job_name": { "type": "string" },
        "stage": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
