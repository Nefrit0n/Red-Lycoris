{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://red-lycoris.dev/contracts/schemas/v1/ingest-run-init-request.schema.json",
  "title": "IngestRunInitRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["provider", "metadata", "artifacts"],
  "properties": {
    "provider": { "type": "string", "const": "gitlab" },
    "metadata": { "$ref": "./ingest-metadata.schema.json" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size_bytes", "sha256", "media_type", "format_hint"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "size_bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "media_type": { "type": "string", "minLength": 1 },
          "format_hint": { "type": "string", "minLength": 1 },
          "tool_name": { "type": "string" },
          "tool_version": { "type": "string" }
        }
      }
    }
  }
}
