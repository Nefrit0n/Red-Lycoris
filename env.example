# ──────────────────────────────────────
# Red Lycoris — Environment Configuration
# ──────────────────────────────────────
# Скопируй в .env и заполни значения:
#   cp .env.example .env

# ── PostgreSQL ──
POSTGRES_DB=redlycoris
POSTGRES_USER=redlycoris
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PORT=6379

# ── Backend API ──
ENV=dev
API_PORT=8080
LOG_LEVEL=info    # debug | info | warn | error
# Длительность сессии (формат Go duration), по умолчанию 168h (7 дней)
SESSION_DURATION=168h
# Использовать secure-cookie:
# - по умолчанию true для ENV != dev
# - в dev обычно false, если нет HTTPS
COOKIE_SECURE=false
# Доверять X-Forwarded-For от прокси (включать только за доверенным reverse-proxy)
TRUST_PROXY=false

# ── Frontend ──
FRONTEND_PORT=3000
FRONTEND_TARGET=development    # development | production

# ── Обогащение ──
ENRICHMENT_ENABLED=true

# NVD API Key (опционально, но увеличивает rate limit с 5 до 50 req/30s)
# Получить: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── CORS ──
# Добавь свои домены через запятую если нужно
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
