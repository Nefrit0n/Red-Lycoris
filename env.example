# ──────────────────────────────────────
# Red Lycoris — Environment Configuration
# ──────────────────────────────────────
# Скопируй в .env и заполни значения:
#   cp env.example .env
#
# ВАЖНО для production:
#   - Задай уникальные POSTGRES_PASSWORD и BOOTSTRAP_ADMIN_PASSWORD
#   - Установи COOKIE_SECURE=true при работе через HTTPS
#   - Не коммить .env в репозиторий


# ── PostgreSQL (docker-compose) ──
POSTGRES_DB=redlycoris
POSTGRES_USER=redlycoris
# ОБЯЗАТЕЛЬНО для production: замените на надёжный пароль (мин. 20 символов)
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# ── Redis (docker-compose) ──
REDIS_PORT=6379

# ── Backend — подключения ──
# Используется кодом напрямую (config.Config). Если запускаешь вне docker-compose,
# убедись что значения соответствуют реальным адресам.
DATABASE_URL=postgres://redlycoris:redlycoris@localhost:5432/redlycoris?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# ── Backend API ──
ENV=dev                 # dev | production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info          # debug | info | warn | error; в production рекомендуется warn

# Длительность сессии (формат Go duration), по умолчанию 168h (7 дней)
SESSION_DURATION=168h

# Использовать Secure-флаг для cookie rl_session.
# ОБЯЗАТЕЛЬНО установить true при работе через HTTPS в production.
# По умолчанию: true для ENV=production, false для ENV=dev.
COOKIE_SECURE=false

# Доверять заголовку X-Forwarded-For от прокси.
# Включать ТОЛЬКО если приложение стоит за доверенным reverse proxy (nginx/Traefik).
# При false используется RemoteAddr напрямую.
TRUST_PROXY=false

# Bootstrap admin — создаётся автоматически при пустой таблице users.
# ОБЯЗАТЕЛЬНО сменить пароль после первого входа.
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_PASSWORD=admin   # ОБЯЗАТЕЛЬНО замените в production
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
BOOTSTRAP_ADMIN_FORCE_PASSWORD_CHANGE=true

# ── Frontend ──
FRONTEND_PORT=3000
FRONTEND_TARGET=development    # development (Vite dev server) | production (nginx)

# ── Обогащение ──
ENRICHMENT_ENABLED=true

# NVD API Key (опционально, но увеличивает rate limit с 5 до 50 req/30s)
# Получить: https://nvd.nist.gov/developers/request-an-api-key
# Без ключа первичная синхронизация NVD займёт несколько часов.
NVD_API_KEY=

# ── CORS ──
# Список разрешённых origin через запятую.
# В production задайте явно — не используйте wildcard (*).
# CORS_ORIGINS=https://your-domain.example.com

# ── TLS (certinit, только prod overlay) ──
# Каталог с пользовательскими сертификатами (bind-mount read-only).
# Если пуст — certinit сгенерирует самоподписанный сертификат автоматически.
# Чтобы использовать свой сертификат, положи в этот каталог:
#   tls.key  — закрытый ключ (ECDSA или RSA)
#   tls.crt  — сертификат сервера (leaf или уже с цепочкой)
#   ca.crt   — (опционально) CA-цепочка; склеивается с tls.crt в fullchain
# RL_TLS_CUSTOM_DIR=./tls-custom

# Имя хоста для добавления в SAN самоподписанного сертификата.
# RL_HOSTNAME=your-server.example.com

# Дополнительные SAN через запятую (добавляются только для self-signed режима).
# RL_TLS_SANS=10.0.0.5,internal.example.com

# ── Версионирование (задаются через scripts/build.sh, не вручную) ──
# VERSION=0.1.0b
# COMMIT=abc1234
# BUILD_DATE=2026-04-22T10:00:00Z
