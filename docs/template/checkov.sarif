{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Checkov",
          "rules": [
            {
              "id": "CKV_AWS_1",
              "name": "CKV_AWS_1",
              "shortDescription": {
                "text": "Ensure S3 bucket has versioning enabled"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CKV_AWS_1",
          "level": "error",
          "message": {
            "text": "Ensure S3 bucket has versioning enabled"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.tf"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
