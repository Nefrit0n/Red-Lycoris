{"$schema":"https://raw.githubusercontent.com/oasis-tcs/sarif-spec/3a361e0bc07860055a926e0d41df405c6f0eb3d4/Documents/CommitteeSpecifications/2.1.0/sarif-schema-2.1.0.json","version":"2.1.0","runs":[{"tool":{"driver":{"name":"appScreener","organization":"Solar appScreener","product":"appScreener","fullName":"Solar appScreener","version":"3.15.2","notifications":[],"rules":[],"taxa":[],"locations":[],"language":"en-US","contents":["localizedData","nonLocalizedData"],"isComprehensive":false,"supportedTaxonomies":[]},"extensions":[]},"invocations":[],"language":"en-US","versionControlProvenance":[],"artifacts":[],"logicalLocations":[],"graphs":[],"results":[{"ruleId":"SCA","ruleIndex":-1,"kind":"fail","level":"error","message":{"text":"Flask is a lightweight WSGI web application framework. When all of the following conditions are met, a response containing data intended for one client may be cached and subsequently sent by the proxy to other clients. If the proxy also caches `Set-Cookie` headers, it may send one client's `session` cookie to other clients. The severity depends on the application's use of the session and the proxy's behavior regarding cookies. The risk depends on all these conditions being met.\n\n1. The application must be hosted behind a caching proxy that does not strip cookies or ignore responses with cookies.\n2. The application sets `session.permanent = True`\n3. The application does not access or modify the session at any point during a request.\n4. `SESSION_REFRESH_EACH_REQUEST` enabled (the default).\n5. The application does not set a `Cache-Control` header to indicate that a page is private or should not be cached.\n\nThis happens because vulnerable versions of Flask only set the `Vary: Cookie` header when the session is accessed or modified, not when it is refreshed (re-sent to update the expiration) without being accessed or modified. This issue has been fixed in versions 2.3.2 and 2.2.5.","arguments":[]},"locations":[{"id":-1,"logicalLocations":[{"name":"flask","index":-1,"parentIndex":-1,"properties":{"tags":[],"x-origin":{"id":121582,"scan":558,"sbomId":"pkg:pypi/flask@2.0.1?package-id=90389e86c072a122","group":"","name":"flask","cpe":"cpe:2.3:a:python-flask:python-flask:2.0.1:*:*:*:*:*:*:*","purl":"pkg:pypi/flask@2.0.1","version":"2.0.1","type":"library","direct":false,"licenses":[]}}}],"annotations":[],"relationships":[]}],"stacks":[],"codeFlows":[],"graphs":[],"graphTraversals":[],"relatedLocations":[],"suppressions":[],"rank":-1.0,"attachments":[],"workItemUris":[],"fixes":[],"taxa":[],"properties":{"tags":[],"x-origin":{"id":35048,"scaId":"CVE-2023-30861","sourceName":"NVD","sourceUrl":"","severity":3,"description":"Flask is a lightweight WSGI web application framework. When all of the following conditions are met, a response containing data intended for one client may be cached and subsequently sent by the proxy to other clients. If the proxy also caches `Set-Cookie` headers, it may send one client's `session` cookie to other clients. The severity depends on the application's use of the session and the proxy's behavior regarding cookies. The risk depends on all these conditions being met.\n\n1. The application must be hosted behind a caching proxy that does not strip cookies or ignore responses with cookies.\n2. The application sets `session.permanent = True`\n3. The application does not access or modify the session at any point during a request.\n4. `SESSION_REFRESH_EACH_REQUEST` enabled (the default).\n5. The application does not set a `Cache-Control` header to indicate that a page is private or should not be cached.\n\nThis happens because vulnerable versions of Flask only set the `Vary: Cookie` header when the session is accessed or modified, not when it is refreshed (re-sent to update the expiration) without being accessed or modified. This issue has been fixed in versions 2.3.2 and 2.2.5.","published":"2023-05-02T18:15:00Z","updated":"2024-11-21T08:00:00Z","cwe":[],"rating":[{"method":"CVSSv3","score":7.5,"severity":"High","sourceName":"NVD","sourceUrl":"https://nvd.nist.gov/","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N"}],"verification":"NOT_PROCESSED","type":"SCA","isUserSeverity":false,"sast":[],"epss":0.00228,"percentile":0.61349,"aliases":["GHSA-m2qf-hxjv-5gpq","BDU:2023-02381","CVE-2023-30861"],"versionEnd":"2.2.5","versionStart":"0","affectedFunctions":[],"versionEndIsIncluding":false,"references":[{"url":"https://github.com/pallets/flask/commit/70f906c51ce49c485f1d355703e9cc3386b1cc2b","type":""},{"url":"https://github.com/pallets/flask/commit/afd63b16170b7c047f5758eb910c416511e9c965","type":""},{"url":"https://github.com/pallets/flask/releases/tag/2.2.5","type":""},{"url":"https://github.com/pallets/flask/releases/tag/2.3.2","type":""},{"url":"https://github.com/pallets/flask/security/advisories/GHSA-m2qf-hxjv-5gpq","type":""},{"url":"https://lists.debian.org/debian-lts-announce/2023/08/msg00024.html","type":""},{"url":"https://security.netapp.com/advisory/ntap-20230818-0006/","type":""},{"url":"https://www.debian.org/security/2023/dsa-5442","type":""},{"url":"https://github.com/pallets/flask/commit/70f906c51ce49c485f1d355703e9cc3386b1cc2b","type":""},{"url":"https://www.debian.org/security/2023/dsa-5442","type":""},{"url":"https://security.netapp.com/advisory/ntap-20230818-0006/","type":""},{"url":"https://lists.debian.org/debian-lts-announce/2023/08/msg00024.html","type":""},{"url":"https://github.com/pallets/flask/security/advisories/GHSA-m2qf-hxjv-5gpq","type":""},{"url":"https://github.com/pallets/flask/releases/tag/2.3.2","type":""},{"url":"https://github.com/pallets/flask/releases/tag/2.2.5","type":""},{"url":"https://github.com/pallets/flask/commit/afd63b16170b7c047f5758eb910c416511e9c965","type":""},{"url":"https://nvd.nist.gov/vuln/detail/CVE-2023-30861","type":"ADVISORY"},{"url":"https://github.com/pallets/flask","type":"PACKAGE"},{"url":"https://github.com/pypa/advisory-database/tree/main/vulns/flask/PYSEC-2023-62.yaml","type":"WEB"},{"url":"https://security.netapp.com/advisory/ntap-20230818-0006","type":"WEB"}],"versions":[],"scaComponent":121582}}},{"ruleId":"SCA","ruleIndex":-1,"kind":"fail","level":"warning","message":{"text":"Requests is a HTTP library. Prior to 2.32.0, when making requests through a Requests `Session`, if the first request is made with `verify=False` to disable cert verification, all subsequent requests to the same host will continue to ignore cert verification regardless of changes to the value of `verify`. This behavior will continue for the lifecycle of the connection in the connection pool. This vulnerability is fixed in 2.32.0.","arguments":[]},"locations":[{"id":-1,"logicalLocations":[{"name":"requests","index":-1,"parentIndex":-1,"properties":{"tags":[],"x-origin":{"id":121584,"scan":558,"sbomId":"pkg:pypi/requests@2.26.0?package-id=00aca6bc0b889d3a","group":"","name":"requests","cpe":"cpe:2.3:a:python:requests:2.26.0:*:*:*:*:*:*:*","purl":"pkg:pypi/requests@2.26.0","version":"2.26.0","type":"library","direct":false,"licenses":[]}}}],"annotations":[],"relationships":[]}],"stacks":[],"codeFlows":[],"graphs":[],"graphTraversals":[],"relatedLocations":[],"suppressions":[],"rank":-1.0,"attachments":[],"workItemUris":[],"fixes":[],"taxa":[],"properties":{"tags":[],"x-origin":{"id":35050,"scaId":"CVE-2024-35195","sourceName":"NVD","sourceUrl":"","severity":2,"description":"Requests is a HTTP library. Prior to 2.32.0, when making requests through a Requests `Session`, if the first request is made with `verify=False` to disable cert verification, all subsequent requests to the same host will continue to ignore cert verification regardless of changes to the value of `verify`. This behavior will continue for the lifecycle of the connection in the connection pool. This vulnerability is fixed in 2.32.0.","published":"2024-05-20T21:15:00Z","updated":"2024-11-21T09:19:00Z","cwe":[],"rating":[{"method":"CVSSv3","score":5.6,"severity":"Medium","sourceName":"NVD","sourceUrl":"https://nvd.nist.gov/","vector":"CVSS:3.1/AV:L/AC:H/PR:H/UI:R/S:U/C:H/I:H/A:N"}],"verification":"NOT_PROCESSED","type":"SCA","isUserSeverity":false,"sast":[],"epss":4.5E-4,"percentile":0.18325,"aliases":["GHSA-9wx4-h78v-vm56","BDU:2024-07014","CVE-2024-35195"],"versionEnd":"2.32.0","versionStart":"0","affectedFunctions":[],"versionEndIsIncluding":false,"references":[{"url":"https://github.com/psf/requests/commit/a58d7f2ffb4d00b46dca2d70a3932a0b37e22fac","type":""},{"url":"https://github.com/psf/requests/commit/a58d7f2ffb4d00b46dca2d70a3932a0b37e22fac","type":""},{"url":"https://github.com/psf/requests/pull/6655","type":""},{"url":"https://github.com/psf/requests/pull/6655","type":""},{"url":"https://github.com/psf/requests/security/advisories/GHSA-9wx4-h78v-vm56","type":""},{"url":"https://github.com/psf/requests/security/advisories/GHSA-9wx4-h78v-vm56","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/IYLSNK5TL46Q6XPRVMHVWS63MVJQOK4Q/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/IYLSNK5TL46Q6XPRVMHVWS63MVJQOK4Q/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/N7WP6EYDSUOCOJYHDK5NX43PYZ4SNHGZ/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/N7WP6EYDSUOCOJYHDK5NX43PYZ4SNHGZ/","type":""},{"url":"https://nvd.nist.gov/vuln/detail/CVE-2024-35195","type":"ADVISORY"},{"url":"https://github.com/psf/requests","type":"PACKAGE"},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/IYLSNK5TL46Q6XPRVMHVWS63MVJQOK4Q","type":"WEB"},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/N7WP6EYDSUOCOJYHDK5NX43PYZ4SNHGZ","type":"WEB"}],"versions":[],"scaComponent":121584}}},{"ruleId":"SCA","ruleIndex":-1,"kind":"fail","level":"warning","message":{"text":"Requests is a HTTP library. Since Requests 2.3.0, Requests has been leaking Proxy-Authorization headers to destination servers when redirected to an HTTPS endpoint. This is a product of how we use `rebuild_proxies` to reattach the `Proxy-Authorization` header to requests. For HTTP connections sent through the tunnel, the proxy will identify the header in the request itself and remove it prior to forwarding to the destination server. However when sent over HTTPS, the `Proxy-Authorization` header must be sent in the CONNECT request as the proxy has no visibility into the tunneled request. This results in Requests forwarding proxy credentials to the destination server unintentionally, allowing a malicious actor to potentially exfiltrate sensitive information. This issue has been patched in version 2.31.0.","arguments":[]},"locations":[{"id":-1,"logicalLocations":[{"name":"requests","index":-1,"parentIndex":-1,"properties":{"tags":[],"x-origin":{"id":121584,"scan":558,"sbomId":"pkg:pypi/requests@2.26.0?package-id=00aca6bc0b889d3a","group":"","name":"requests","cpe":"cpe:2.3:a:python:requests:2.26.0:*:*:*:*:*:*:*","purl":"pkg:pypi/requests@2.26.0","version":"2.26.0","type":"library","direct":false,"licenses":[]}}}],"annotations":[],"relationships":[]}],"stacks":[],"codeFlows":[],"graphs":[],"graphTraversals":[],"relatedLocations":[],"suppressions":[],"rank":-1.0,"attachments":[],"workItemUris":[],"fixes":[],"taxa":[],"properties":{"tags":[],"x-origin":{"id":35049,"scaId":"CVE-2023-32681","sourceName":"NVD","sourceUrl":"","severity":2,"description":"Requests is a HTTP library. Since Requests 2.3.0, Requests has been leaking Proxy-Authorization headers to destination servers when redirected to an HTTPS endpoint. This is a product of how we use `rebuild_proxies` to reattach the `Proxy-Authorization` header to requests. For HTTP connections sent through the tunnel, the proxy will identify the header in the request itself and remove it prior to forwarding to the destination server. However when sent over HTTPS, the `Proxy-Authorization` header must be sent in the CONNECT request as the proxy has no visibility into the tunneled request. This results in Requests forwarding proxy credentials to the destination server unintentionally, allowing a malicious actor to potentially exfiltrate sensitive information. This issue has been patched in version 2.31.0.","published":"2023-05-26T18:15:00Z","updated":"2025-02-13T17:16:00Z","cwe":[],"rating":[{"method":"CVSSv3","score":6.1,"severity":"Medium","sourceName":"NVD","sourceUrl":"https://nvd.nist.gov/","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:R/S:C/C:H/I:N/A:N"}],"verification":"NOT_PROCESSED","type":"SCA","isUserSeverity":false,"sast":[],"epss":0.00306,"percentile":0.70006,"aliases":["GHSA-j8r2-6x86-q33q","BDU:2023-03874","CVE-2023-32681","NVD-CWE-noinfo"],"versionEnd":"2.31.0","versionStart":"2.3.0","affectedFunctions":[],"versionEndIsIncluding":false,"references":[{"url":"https://github.com/psf/requests/commit/74ea7cf7a6a27a4eeb2ae24e162bcc942a6706d5","type":""},{"url":"https://github.com/psf/requests/commit/74ea7cf7a6a27a4eeb2ae24e162bcc942a6706d5","type":""},{"url":"https://github.com/psf/requests/releases/tag/v2.31.0","type":""},{"url":"https://github.com/psf/requests/releases/tag/v2.31.0","type":""},{"url":"https://github.com/psf/requests/security/advisories/GHSA-j8r2-6x86-q33q","type":""},{"url":"https://github.com/psf/requests/security/advisories/GHSA-j8r2-6x86-q33q","type":""},{"url":"https://lists.debian.org/debian-lts-announce/2023/06/msg00018.html","type":""},{"url":"https://lists.debian.org/debian-lts-announce/2023/06/msg00018.html","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/AW7HNFGYP44RT3DUDQXG2QT3OEV2PJ7Y/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/AW7HNFGYP44RT3DUDQXG2QT3OEV2PJ7Y/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/KOYASTZDGQG2BWLSNBPL3TQRL2G7QYNZ/","type":""},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/KOYASTZDGQG2BWLSNBPL3TQRL2G7QYNZ/","type":""},{"url":"https://security.gentoo.org/glsa/202309-08","type":""},{"url":"https://security.gentoo.org/glsa/202309-08","type":""},{"url":"https://nvd.nist.gov/vuln/detail/CVE-2023-32681","type":"ADVISORY"},{"url":"https://github.com/psf/requests","type":"PACKAGE"},{"url":"https://github.com/pypa/advisory-database/tree/main/vulns/requests/PYSEC-2023-74.yaml","type":"WEB"},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/AW7HNFGYP44RT3DUDQXG2QT3OEV2PJ7Y","type":"WEB"},{"url":"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/KOYASTZDGQG2BWLSNBPL3TQRL2G7QYNZ","type":"WEB"}],"versions":[],"scaComponent":121584}}}],"runAggregates":[],"redactionTokens":[],"newlineSequences":["\r\n","\n"],"threadFlowLocations":[],"taxonomies":[],"addresses":[],"translations":[],"policies":[],"webRequests":[],"webResponses":[],"properties":{"tags":[],"x-duration":"1978","x-project-uuid":"1c99be18-b75b-43db-9dd3-941d689f1dab","x-project-name":"SCA.DSO_TEST"}}],"inlineExternalProperties":[]}